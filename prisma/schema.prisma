generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  bio          String?
  skillTags    String   @default("[]")
  socialLinks  String   @default("{}")
  flakeRate    Float    @default(0)
  profileSetup Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  projects     Project[]
  coopListings CoopListing[]
}

model Project {
  id              String       @id @default(cuid())
  title           String
  description     String
  domain          String
  effortRemaining String
  status          String       @default("Active")
  contextSnapshot String       @default("{}")
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  statusLogs      StatusLog[]
  microTasks      MicroTask[]
  coopListing     CoopListing?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model MicroTask {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId           Int
  title            String
  description      String
  estimatedMinutes Int
  category         String
  dependencies     String   @default("[]")
  status           String   @default("pending")
  order            Int
  batchId          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CoopListing {
  id               String   @id @default(cuid())
  projectId        String   @unique
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  description      String
  domainTags       String   @default("[]")
  skillTagsHave    String   @default("[]")
  skillTagsNeed    String   @default("[]")
  timeCommitment   String
  milestonePreview String
  status           String   @default("Open")
  visibility       String   @default("Open to All")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model StatusLog {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  fromStatus String
  toStatus   String
  notes      String?
  createdAt  DateTime @default(now())
}
