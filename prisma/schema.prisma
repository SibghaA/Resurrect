generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String?
  bio                 String?
  skillTags           String   @default("[]")
  socialLinks         String   @default("{}")
  flakeRate           Float    @default(0)
  profileSetup        Boolean  @default(false)
  tier                String   @default("free")
  aiCallsThisMonth    Int      @default(0)
  aiCallsResetAt      DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  projects            Project[]
  coopListings        CoopListing[]
  initiatedCollabs    Collaboration[] @relation("InitiatedCollabs")
  joinedCollabs       Collaboration[] @relation("JoinedCollabs")
}

model Project {
  id              String       @id @default(cuid())
  title           String
  description     String
  domain          String
  effortRemaining String
  status          String       @default("Active")
  contextSnapshot String       @default("{}")
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  statusLogs      StatusLog[]
  microTasks      MicroTask[]
  coopListing     CoopListing?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model MicroTask {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId           Int
  title            String
  description      String
  estimatedMinutes Int
  category         String
  dependencies     String   @default("[]")
  status           String   @default("pending")
  order            Int
  batchId          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CoopListing {
  id               String   @id @default(cuid())
  projectId        String   @unique
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  description      String
  domainTags       String   @default("[]")
  skillTagsHave    String   @default("[]")
  skillTagsNeed    String   @default("[]")
  timeCommitment   String
  milestonePreview String
  status           String   @default("Open")
  visibility       String   @default("Open to All")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  collaborations   Collaboration[]
}

model StatusLog {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  fromStatus String
  toStatus   String
  notes      String?
  createdAt  DateTime @default(now())
}

model AiTaskCache {
  id        String   @id @default(cuid())
  projectId String
  cacheKey  String
  tasksJson String
  source    String   @default("ai")
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([projectId, cacheKey])
}

model Collaboration {
  id                  String    @id @default(cuid())
  listingId           String
  listing             CoopListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  initiatorId         String
  collaboratorId      String
  initiator           User      @relation("InitiatedCollabs", fields: [initiatorId], references: [id])
  collaborator        User      @relation("JoinedCollabs",     fields: [collaboratorId], references: [id])
  status              String    @default("Active")
  milestoneDeadline   DateTime?
  lastCommunicationAt DateTime?
  exitTriggeredAt     DateTime?
  handoffCompletedAt  DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  flags               CollaborationFlag[]
}

model CollaborationFlag {
  id              String        @id @default(cuid())
  collaborationId String
  collaboration   Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  raisedById      String
  reason          String
  status          String        @default("Pending")
  createdAt       DateTime      @default(now())
}
